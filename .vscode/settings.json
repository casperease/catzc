{
  // Markdown settings (built-in preview)
  "markdown.preview.fontFamily": "Consolas, 'Courier New', monospace",
  "markdown.styles": [
    ".vscode/markdown-preview-dark.css"
  ],
  "markdown.preview.lineHeight": 1.6,
  "markdown.preview.fontSize": 14,
  "markdown.preview.scrollPreviewWithEditor": true,
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.preview.markEditorSelection": true,

  // Markdown Preview Enhanced settings
  "markdown-preview-enhanced.previewTheme": "one-dark.css",
  "markdown-preview-enhanced.codeBlockTheme": "one-dark.css",

  // PowerShell: use pwsh 7 for the Integrated Console
  "powershell.powerShellDefaultVersion": "PowerShell (x64)",

  // PowerShell: use project PSScriptAnalyzer settings for analysis (squiggles)
  "powershell.scriptAnalysis.settingsPath": "./automation/.internal/assets/PSScriptAnalyzerSettings.psd1",

  // PowerShell: "Format Document" uses these codeFormatting settings — NOT the psd1 — so they must be
  // kept in sync with PSScriptAnalyzerSettings.psd1, or the formatter and analyzer disagree.
  // Pipeline indentation: match the psd1's PSUseConsistentIndentation PipelineIndentation setting,
  // otherwise the formatter leaves a piped line under-indented and the analyzer flags it.
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  // Expand aliases on format — the psd1 enforces PSAvoidUsingCmdletAliases.
  "powershell.codeFormatting.autoCorrectAliases": true,
  // Leave casing alone — PSUseCorrectCasing is disabled in the psd1 (false positives on Pester params).
  "powershell.codeFormatting.useCorrectCasing": false,
  // Vertically align hashtable key/value pairs on format. Matches the psd1's PSUseConsistentWhitespace
  // IgnoreAssignmentOperatorInsideHashTable = $true, so the analyzer accepts the aligned '='.
  "powershell.codeFormatting.alignPropertyValuePairs": true,
  // Break one-line blocks (if ($x) { ... }) across multiple lines on format, so no block keeps its
  // { } on a single line. Matches the psd1's PSPlaceOpenBrace/PSPlaceCloseBrace IgnoreOneLineBlock = $false.
  "powershell.codeFormatting.ignoreOneLineBlock": false,
  // Honour .editorconfig / 4-space indent; don't let VS Code guess indentation from file contents.
  "[powershell]": {
    "editor.detectIndentation": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // Exclude vendored modules and generated module manifests from search. Manifests (automation/**/*.psd1)
  // are gitignored build output — canonical by their generator (Bootstrap), promoted to versioned immutable
  // feed artifacts — so they are not authored here and should not clutter search. The authored analyzer
  // config now lives under automation/.internal/assets and would fall under that glob, so it is explicitly
  // un-excluded (a more specific `false` wins) to keep it searchable and visible.
  "search.exclude": {
    "automation/.vendor": true,
    "automation/**/*.psd1": true,
    "automation/.internal/assets/PSScriptAnalyzerSettings.psd1": false
  },
  // Do not watch/reformat generated manifests — they are regenerated by the importer, not hand-edited. The
  // authored analyzer config is hand-edited, so keep watching it (un-exclude past the manifest glob).
  "files.watcherExclude": {
    "**/automation/**/*.psd1": true,
    "**/automation/.internal/assets/PSScriptAnalyzerSettings.psd1": false
  },

  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.quickSuggestions": {
      "comments": "on",
      "strings": "on",
      "other": "on"
    },
    "editor.wordWrap": "off"
  },

  // Treat LICENSE files as plain text so markdownlint ignores them
  // .yml -> generic YAML, .yaml -> Azure Pipelines YAML
  // .markdownlintignore -> "ignore" (the built-in .gitignore language) so it is treated as a
  // gitignore-syntax ignore file, not as Markdown.
  "files.associations": {
    "**/LICENSE": "plaintext",
    "**/*.yml": "yaml",
    "**/*.yaml": "azure-pipelines",
    "**/.markdownlintignore": "ignore"
  },

  // Spell checking — the single repo dictionary lives in /cspell.yml (auto-discovered by Code Spell
  // Checker; the extension is recommended in .vscode/extensions.json).
  "cSpell.enabled": true,
  // Information = blue squiggle (Error = red, Warning = yellow).
  "cSpell.diagnosticLevel": "Information",
}
