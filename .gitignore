# GENERATED FILE — do not edit. Single source of truth:
#   automation/Catzc.Base.Git/configs/gitignore.yml (zones; rendered by New-GitIgnore)
#   automation/Catzc.Base.RootConfig/configs/rootconfig.yml (the injected managed-copies zone)
# Regenerated on import by Build-RootConfig; committed, so a fresh clone ignores correctly from checkout.

# ── Local, never-committed files ────────────────────────────────────────────────────────────────────────────────────
# Per-machine working files: local agent instructions and MCP wiring, scratch folders, editor backups, and the
# occasional bash-on-Windows crash dump.
.claude/CLAUDE.local.md
.mcp.json
tmp
*.bkp
bash.exe.stackdump

# ── Output directory ────────────────────────────────────────────────────────────────────────────────────────────────
# All generated artifacts land in out/ (see docs/adr/repository/dedicated-output-directory.md). The folder itself is
# kept so a fresh checkout has the anchor; its contents never enter git.
out/*
!out/.gitkeep  # keep the folder, ignore its contents

# ── Generated module manifests ──────────────────────────────────────────────────────────────────────────────────────
# Every module's <Module>.psd1 is generated by the loader on import (open-closed architecture) — derived, never
# committed. Vendored third-party modules ship their own authored manifests, and the authored analyzer config under
# .internal/assets is a config file that merely shares the extension, so both opt back in past the glob.
automation/**/*.psd1
!automation/.vendor/**/*.psd1                               # vendored modules ship their own manifests
!automation/.internal/assets/PSScriptAnalyzerSettings.psd1  # authored analyzer source

# ── Managed root-config copies ──────────────────────────────────────────────────────────────────────────────────────
# Repository-root config files fully managed by Catzc.Base.RootConfig — each reproduced on import from its one in-repo
# source of truth (see rootconfig.yml). Edit the source, never the root copy; this list is injected from the
# registry's committed:false targets and never restated by hand.
/PSScriptAnalyzerSettings.psd1
/.vscode/settings.json
/.vscode/extensions.json
/.vscode/launch.json
/.vscode/azure-pipelines-schema.json
/.vscode/markdown-preview-dark.css
/.editorconfig
/.markdownlint.yml
/.markdownlintignore
/.prettierrc.yml
/.prettierignore
/.cspell/.gitignore
/cspell.yml
/dotnet-tools.json
/catzc.sln

# ── Generated README links ──────────────────────────────────────────────────────────────────────────────────────────
# A README.md in a mapped conventional folder is a filesystem link to an authored docs source (Build-Readme,
# Catzc.Base.Docs; see docs/adr/repository/generated-readmes.md) — derived artifacts like the module manifests,
# re-linked on every import. Hand-authored READMEs are exactly the unmapped folders and opt back in below. The
# generated cspell dictionaries under .cspell/ are ignored by the folder's own managed .gitignore (a root-config
# copy), so only that folder's .gitkeep is committed.
**/README.md
!.github/README.md
!automation/.vendor/**/README.md
!automation/Catzc.Azure.Templates/tests/assets/README.md

# ── Generated ADR index ─────────────────────────────────────────────────────────────────────────────────────────────
# docs/adr/index.md is the ADR code -> rule-citation registry, generated from
# automation/Catzc.Base.Docs/configs/adrs.yml (Build-AdrIndex, materialised on import before the folder README link
# that points at it) — a derived artifact like the generated READMEs. adrs.yml is the single source of truth; edit it,
# never index.md. See docs/adr/repository/generated-readmes.md.
docs/adr/index.md

# ── Compiled C# types — transient temp only ─────────────────────────────────────────────────────────────────────────
# The combined compiled assembly (automation/.compiled/Catzc.Types.<hash>.dll) is COMMITTED — a vendored, hash-keyed
# prebuild that lets a fresh checkout and CI load without compiling (see docs/adr/automation/caching.md). Only the
# concurrent-compile temp file is ignored.
automation/.compiled/*.tmp

# ── IDE-only C# project build output ────────────────────────────────────────────────────────────────────────────────
# The root catzc.sln references automation/.internal/assets/Catzc.Types.csproj for editor tooling, and MSBuild emits
# obj/bin next to that project. The runtime never builds it (Add-Type compiles the type sources at import), so its
# MSBuild artifacts are transient and vscode consumed only. The automation types system builds via the internal
# builder, no csproj or sln involved.
automation/.internal/assets/obj/
automation/.internal/assets/bin/
